import { useState, useEffect } from "react";
import { collection, query, where, getDocs, deleteDoc, doc } from "firebase/firestore";
import { db } from "../firebase";

// NOTE: orderBy("date","desc") removed entirely -- requires a composite Firestore index
// that is not guaranteed to exist. We sort client-side instead. This is the fix for
// screening results not appearing in history.

const SCORE_COLOURS = {
  "Positive screen":  "#C4956A",
  "Negative screen":  "#7A9B7A",
  "Probable PTSD":    "#C4956A",
  "Moderate symptoms":"#B8A87A",
  "Minimal symptoms": "#7A9B7A",
};

const GUIDES = {
  pcl5: [
    { range:"0 - 19",  label:"Minimal symptoms",  color:"#7A9B7A", desc:"Very few PTSD symptoms. Keep monitoring and using preventive coping tools." },
    { range:"20 - 32", label:"Moderate symptoms", color:"#B8A87A", desc:"Moderate symptoms present. Speaking with a counsellor would be beneficial." },
    { range:"33 - 80", label:"Probable PTSD",     color:"#C4956A", desc:"Symptoms consistent with PTSD. Please seek a full professional evaluation." },
  ],
  pc5: [
    { range:"0 - 2", label:"Negative screen", color:"#7A9B7A", desc:"Below the threshold. Continue monitoring if you are still experiencing symptoms." },
    { range:"3 - 5", label:"Positive screen", color:"#C4956A", desc:"Positive screen -- a full clinical evaluation by a professional is recommended." },
  ],
};

const GUIDES_ZU = {
  pcl5: [
    { range:"0 - 19",  label:"Izibonakaliso ezincane",    color:"#7A9B7A", desc:"Izibonakaliso ze-PTSD ezimbalwa kakhulu. Qhubeka uqapha." },
    { range:"20 - 32", label:"Izibonakaliso ezifaneleyo", color:"#B8A87A", desc:"Izibonakaliso ezifaneleyo zikhona. Ukuxoxa nomuntu ongasiza kuzosiza." },
    { range:"33 - 80", label:"I-PTSD engabonakala",       color:"#C4956A", desc:"Izibonakaliso ezifanele i-PTSD. Cela ukuhlolwa ngokugcwele uchwepheshe." },
  ],
  pc5: [
    { range:"0 - 2", label:"Uhlolo olungemuhle", color:"#7A9B7A", desc:"Ngaphansi komnyango. Qhubeka uqapha uma usenazo izibonakaliso." },
    { range:"3 - 5", label:"Uhlolo olumuhle",    color:"#C4956A", desc:"Uhlolo olumuhle -- ukuhlolwa ngokugcwele uchwepheshe kuyacelwa." },
  ],
};

const LANG = {
  en: {
    title:"Screening History", back:"<- Dashboard",
    noHistory:"You haven't saved any screening results yet.",
    takeTest:"Take a Screening Test", score:"score",
    deleteBtn:"Delete", confirmDelete:"Delete this result?",
    loading:"Loading your history...",
    pcl5Guide:"PCL-5 Score Guide", pc5Guide:"PC-PTSD-5 Score Guide",
    retake:"Retake ->",
    errorMsg:"Could not load history. Check your connection and try again.",
  },
  zu: {
    title:"Umlando Wokuhlola", back:"<- Ibhodi",
    noHistory:"Awukagcini imiphumela yokuhlola.",
    takeTest:"Thatha Uhlolo", score:"inani",
    deleteBtn:"Susa", confirmDelete:"Susa lo mphumela?",
    loading:"Ilowunda umlando wakho...",
    pcl5Guide:"Isiqondiso Samanani e-PCL-5", pc5Guide:"Isiqondiso Samanani e-PC-PTSD-5",
    retake:"Phinda ->",
    errorMsg:"Yehlulekile ukulowunda. Hlola uxhumano lwakho ubese uzama futhi.",
  },
};

function ScreeningHistory({ user, setPage, lang = "en" }) {
  const tx     = LANG[lang] || LANG.en;
  const guides = lang === "zu" ? GUIDES_ZU : GUIDES;

  const [results, setResults]         = useState([]);
  const [loading, setLoading]         = useState(true);
  const [fetchError, setFetchError]   = useState("");
  const [activeGuide, setActiveGuide] = useState("pcl5");

  useEffect(() => {
    let cancelled = false;

    const loadHistory = async () => {
      setLoading(true);
      setFetchError("");
      try {
        // Simple query -- no orderBy so no composite index needed
        const q = query(
          collection(db, "screenings"),
          where("userId", "==", user.uid)
        );
        const snap = await getDocs(q);
        const data = snap.docs.map(d => ({ id: d.id, ...d.data() }));

        // Sort client-side: newest first
        data.sort((a, b) => {
          const aTime = a.date?.seconds || 0;
          const bTime = b.date?.seconds || 0;
          return bTime - aTime;
        });

        if (!cancelled) setResults(data);
      } catch (err) {
        console.error("ScreeningHistory load error:", err);
        if (!cancelled) setFetchError(tx.errorMsg);
      }
      if (!cancelled) setLoading(false);
    };

    loadHistory();
    return () => { cancelled = true; };
  }, [user.uid, tx.errorMsg]);

  const handleDelete = async (id) => {
    if (!window.confirm(tx.confirmDelete)) return;
    try {
      await deleteDoc(doc(db, "screenings", id));
      setResults(prev => prev.filter(r => r.id !== id));
    } catch (err) {
      console.error("Delete error:", err);
    }
  };

  const formatDate = (ts) => {
    if (!ts) return "--";
    try {
      const d = ts.seconds ? new Date(ts.seconds * 1000) : new Date(ts);
      return d.toLocaleDateString("en-ZA", { year:"numeric", month:"short", day:"numeric" });
    } catch { return "--"; }
  };

  const guide      = guides[activeGuide] || guides.pcl5;
  const guideTitle = activeGuide === "pcl5" ? tx.pcl5Guide : tx.pc5Guide;

  return (
    <div className="dashboard">
      <div className="top-bar">
        <h1 className="page-title">{tx.title}</h1>
        <button onClick={() => setPage("dashboard")}>{tx.back}</button>
      </div>

      {/* Score guide */}
      <div className="hist-guide-card">
        <div className="hist-guide-tabs">
          <button className={`hist-guide-tab${activeGuide === "pcl5" ? " active" : ""}`}
            onClick={() => setActiveGuide("pcl5")}>PCL-5</button>
          <button className={`hist-guide-tab${activeGuide === "pc5" ? " active" : ""}`}
            onClick={() => setActiveGuide("pc5")}>PC-PTSD-5</button>
        </div>
        <h3 className="hist-guide-title">{guideTitle}</h3>
        <div className="hist-guide-rows">
          {guide.map(g => (
            <div className="hist-guide-row" key={g.range} style={{ borderLeftColor: g.color }}>
              <div className="hist-guide-range" style={{ color: g.color }}>{g.range}</div>
              <div>
                <div className="hist-guide-label" style={{ color: g.color }}>{g.label}</div>
                <p className="hist-guide-desc">{g.desc}</p>
              </div>
            </div>
          ))}
        </div>
      </div>

      {/* Results */}
      {loading ? (
        <div className="hist-loading">{tx.loading}</div>
      ) : fetchError ? (
        <div className="hist-empty">
          <div className="hist-empty-icon">⚠️</div>
          <p>{fetchError}</p>
          <button className="btn-rose-sm" onClick={() => window.location.reload()}>
            Try Again
          </button>
        </div>
      ) : results.length === 0 ? (
        <div className="hist-empty">
          <div className="hist-empty-icon">📋</div>
          <p>{tx.noHistory}</p>
          <button className="btn-rose-sm" onClick={() => setPage("screening")}>
            {tx.takeTest}
          </button>
        </div>
      ) : (
        <div className="hist-list">
          {results.map(r => {
            const col = SCORE_COLOURS[r.level] || "#C4B5A5";
            return (
              <div className="hist-result-card" key={r.id} style={{ borderLeftColor: col }}>
                <div className="hist-result-top">
                  <div>
                    <div className="hist-test-name">{r.testTitle || r.testId || "Screening"}</div>
                    <div className="hist-result-date">{formatDate(r.date)}</div>
                  </div>
                  <div className="hist-score-circle" style={{ borderColor: col }}>
                    <span className="hist-score-num">{r.score ?? "--"}</span>
                    <span className="hist-score-sub">{tx.score}</span>
                  </div>
                </div>
                <div className="hist-result-level" style={{ color: col }}>
                  {r.level || "--"}
                </div>
                <div className="hist-result-actions">
                  <button className="btn-rose-sm" onClick={() => setPage("screening")}>
                    {tx.retake}
                  </button>
                  <button className="hist-delete-btn" onClick={() => handleDelete(r.id)}>
                    {tx.deleteBtn}
                  </button>
                </div>
              </div>
            );
          })}
        </div>
      )}
    </div>
  );
}

export default ScreeningHistory;